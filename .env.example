# Princess — environment variables. Copy to .env.local and fill.
# NEVER commit real secrets (CLAUDE_RULES §5). See docs/ENV_SETUP.md.

# ---- Client-safe (exposed to the browser) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Server-only (NEVER ship to the browser) ----
# Service-role key BYPASSES RLS — used only by lib/supabase/admin.ts on the server.
SUPABASE_SERVICE_ROLE_KEY=
TAP_SECRET_KEY=
TAP_WEBHOOK_SECRET=
RESEND_API_KEY=

# ---- Optional / later phases (see docs/ENV_SETUP.md) ----
# NEXT_PUBLIC_TAP_PUBLISHABLE_KEY=
# RESEND_FROM_EMAIL="Princess <no-reply@example.com>"
