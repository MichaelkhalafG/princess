{
  "name": "princess",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "db:types": "supabase gen types typescript --linked > lib/database.types.ts",
    "format": "prettier --write .",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "spike:tap": "tsx --tsconfig scripts/tsconfig.json scripts/tap-spike.ts",
    "seed:dummy": "tsx --tsconfig scripts/tsconfig.json scripts/seed-dummy.ts",
    "seed:reset": "tsx --tsconfig scripts/tsconfig.json scripts/seed-dummy.ts --reset"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
